<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Properties>
        <Property name="APP_LOG_ROOT">${sys:path.logs:-./logs}</Property>
        <Property name="APP_NAME">jisocreator</Property>
    </Properties>
    <Appenders>
        <Console name="ConsoleAppender" target="SYSTEM_OUT">
            <PatternLayout pattern="%style{%date{DEFAULT}}{yellow} [%t] %highlight{%-5level}{FATAL=bg_red, ERROR=red, WARN=yellow, INFO=green} (%F:%L) - %message\n"/>
        </Console>
        <RollingFile name="ROLLING_FILE_APPENDER" fileName="${APP_LOG_ROOT}/${APP_NAME}.log" filePattern="${APP_LOG_ROOT}/${APP_NAME}-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout pattern="%d{DEFAULT} [%t] %-5level %C{1}.%M(%F:%L) - %msg%n"/>
            <Policies>
                <SizeBasedTriggeringPolicy size="19500KB"/>
            </Policies>
        </RollingFile>
    </Appenders>
    <Loggers>
        <Root level="debug">
            <AppenderRef ref="ConsoleAppender"/>
        </Root>
        <Logger name="cl.cavallinux" level="debug">
            <AppenderRef ref="ROLLING_FILE_APPENDER"/>
        </Logger>
    </Loggers>
</Configuration>